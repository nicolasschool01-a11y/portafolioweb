// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  email         String   @default("")
  phone         String?
  whatsapp      String?
  company       String?
  projectType   String   @default("Prospect")
  problemSolved String?
  targetUsers   String?
  designStatus  String?
  timeline      String?
  budget        String   @default("")
  contentNeeds  String?
  demoGoal      String?
  extraFeatures String?
  description   String?
  status        String   @default("new")
  sourceSlug    String?
  adminNotes    String?
  
  // Novedades v3.1 (Apify & Smart Outreach)
  website       String?
  mapsUrl       String?
  rating        Float?
  reviewsCount  Int?
  street        String?
  city          String?
  state         String?
  industry      String?
  instagram     String?
  facebook      String?
  leadSource    String   @default("organic") // organic, scraped, linkedIn, etc.
  category      String?
  tags          String?  // Almacenado como JSON comprimido o string simple

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
